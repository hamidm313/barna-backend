PORT=4000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=barna_db
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# CDN - choose one: cloudinary | s3 | local (default)
CDN_PROVIDER=local

# Cloudinary (if CDN_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# S3 / MinIO (if CDN_PROVIDER=s3)
S3_REGION=us-east-1
S3_BUCKET=barna-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=https://s3.amazonaws.com
